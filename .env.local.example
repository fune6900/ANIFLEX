# TMDb 認証設定（どちらか一方を設定してください）
#
# 方式1: API Read Access Token（推奨）
# https://www.themoviedb.org/settings/api の「API読み取りアクセストークン」
TMDB_ACCESS_TOKEN=your_tmdb_read_access_token_here

# 方式2: API Key (v3)
# https://www.themoviedb.org/settings/api の「APIキー」
# TMDB_API_KEY=your_tmdb_api_key_here

# 本番環境のURL（VercelやRenderなどにデプロイ時に設定）
# NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
